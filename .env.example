# Project settings
PROJECT_NAME=Docxy
API_V1_STR=/api/v1
SECRET_KEY=local-dev-secret-key-change-in-production

# Database: SQLite (no PostgreSQL needed)
DATABASE_URL=sqlite+aiosqlite:///./docxy.db

# Redis: disabled (no Redis server required)
USE_REDIS=False
REDIS_URL=

# Storage: local filesystem (uploads go to ./uploads/)
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# Admin credentials (for dashboard – no auth implemented yet)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# LLM settings (not used in dummy worker)
LITELLM_BASE_URL=http://localhost:11434
LITELLM_API_KEY=dummy
LITELLM_MODEL_NAME=dummy

# Rate limiting (uses in‑memory when Redis is off)
INBOUND_RATE_LIMIT=100/hour